<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <!-- ══════════════════════════════════════════
         APP BAR  (collapsing image + toolbar)
    ══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:contentScrim="@color/green_primary"
            app:titleEnabled="false">

            <!-- ── IMAGE VIEWPAGER (slideable product images) ── -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpProductImages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.6"
                android:background="@color/white" />

            <!-- ── GRADIENT OVERLAY (bottom fade) ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_bottom_white"
                app:layout_collapseMode="pin" />

            <!-- ── TOOLBAR (back + share) ── -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_gravity="top"
                app:layout_collapseMode="pin"
                app:contentInsetStart="0dp">

                <!-- Back Button -->
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_icon_btn_white"
                    android:src="@drawable/baseline_arrow_back_ios_24"
                    android:padding="8dp"
                    android:contentDescription="Back" />

                <!-- Share Button — pushed to end -->
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_icon_btn_white"
                    android:src="@drawable/ic_share"
                    android:padding="8dp"
                    android:contentDescription="Share" />

            </androidx.appcompat.widget.Toolbar>

            <!-- ── VIEWPAGER DOT INDICATOR ── -->
<!--            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator-->
<!--                android:id="@+id/dotsIndicator"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_gravity="bottom|center_horizontal"-->
<!--                android:layout_marginBottom="14dp"-->
<!--                app:dotsColor="@color/green_primary"-->
<!--                app:dotsCornerRadius="4dp"-->
<!--                app:dotsSize="8dp"-->
<!--                app:dotsSpacing="5dp"-->
<!--                app:selectedDotColor="@color/green_primary"-->
<!--                app:selectedDotSize="10dp"-->
<!--                app:dotsWidthFactor="2.5"-->
<!--                app:layout_collapseMode="pin" />-->

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>


    <!-- ══════════════════════════════════════════
         SCROLLABLE CONTENT
    ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp">

            <!-- ─────────────────────────────────────
                 CARD 1 · PRODUCT INFO
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Brand Tag -->
                    <TextView
                        android:id="@+id/tvBrandTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DoodhWala · Fresh Daily"
                        android:textSize="10sp"
                        android:textColor="@color/green_primary"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true" />

                    <!-- Product Name -->
                    <TextView
                        android:id="@+id/tvProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="A2 Gir Cow Fresh Milk"
                        android:textSize="20sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="@font/sora_bold"
                        android:lineSpacingMultiplier="1.2" />

                    <!-- Volume / Size -->
                    <TextView
                        android:id="@+id/tvVolume"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="500 ml · Glass Bottle"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:fontFamily="@font/sora_regular" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/border_light" />

                    <!-- Price Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Selling Price -->
                        <TextView
                            android:id="@+id/tvSellingPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹65"
                            android:textSize="28sp"
                            android:textColor="@color/green_primary"
                            android:fontFamily="@font/sora_bold" />

                        <!-- MRP (strikethrough) -->
                        <TextView
                            android:id="@+id/tvMrp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="₹75"
                            android:textSize="14sp"
                            android:textColor="@color/text_muted"
                            android:fontFamily="@font/sora_regular" />

                        <!-- Discount Badge -->
                        <TextView
                            android:id="@+id/tvDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="13% OFF"
                            android:textSize="10sp"
                            android:textColor="@color/green_primary"
                            android:fontFamily="@font/sora_bold"
                            android:background="@drawable/bg_discount_badge"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />

                        <!-- Spacer -->
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                        <!-- In Stock Label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● In Stock"
                            android:textSize="11sp"
                            android:textColor="@color/green_mid"
                            android:fontFamily="@font/sora_bold" />

                    </LinearLayout>

                    <!-- Quantity Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Quantity"
                            android:textSize="13sp"
                            android:textColor="@color/text_mid"
                            android:fontFamily="@font/sora_bold" />

                        <!-- Minus Button -->
                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btnMinus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_qty_btn"
                            android:src="@drawable/ic_minus"
                            android:padding="8dp"
                            android:contentDescription="Decrease quantity" />

                        <!-- Quantity Value -->
                        <TextView
                            android:id="@+id/tvQty"
                            android:layout_width="44dp"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textSize="16sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="@font/sora_bold"
                            android:gravity="center" />

                        <!-- Plus Button -->
                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/btnPlus"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_qty_btn_filled"
                            android:src="@drawable/ic_plus"
                            android:padding="8dp"
                            android:contentDescription="Increase quantity" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- ─────────────────────────────────────
                 CARD 2 · NUTRITION HIGHLIGHTS
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section Header -->
                    <include layout="@layout/view_section_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Nutrition Grid (3 columns) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- Protein -->
                        <include layout="@layout/item_nutrition_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp" />

                        <!-- Fat -->
                        <include layout="@layout/item_nutrition_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp" />

                        <!-- Calcium -->
                        <include layout="@layout/item_nutrition_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp" />

                    </LinearLayout>

                    <!-- Second Row of Stats -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <include layout="@layout/item_nutrition_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp" />

                        <include layout="@layout/item_nutrition_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp" />

                        <include layout="@layout/item_nutrition_stat"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- ─────────────────────────────────────
                 CARD 3 · PRODUCT DETAILS
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/view_section_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Description Text -->
                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Our A2 Gir Cow Milk comes directly from indigenous Gir cows raised on natural pastures in Gujarat. Rich in A2 beta-casein protein, it is easier to digest and packed with essential nutrients. No hormones, no preservatives — just pure, fresh milk delivered to your doorstep every morning."
                        android:textSize="13sp"
                        android:textColor="@color/text_mid"
                        android:fontFamily="@font/sora_regular"
                        android:lineSpacingMultiplier="1.6" />

                    <!-- "Read More" toggle -->
                    <TextView
                        android:id="@+id/tvReadMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Read more ▾"
                        android:textSize="12sp"
                        android:textColor="@color/green_primary"
                        android:fontFamily="@font/sora_bold" />

                    <!-- Key Info Chips Row -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Each chip: bg_chip_green with icon + label -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌿 Organic"
                                android:textSize="11.5sp"
                                android:textColor="@color/green_primary"
                                android:fontFamily="@font/sora_bold"
                                android:background="@drawable/bg_chip_green"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="7dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🐄 Gir Breed"
                                android:textSize="11.5sp"
                                android:textColor="@color/green_primary"
                                android:fontFamily="@font/sora_bold"
                                android:background="@drawable/bg_chip_green"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="7dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🧪 Lab Tested"
                                android:textSize="11.5sp"
                                android:textColor="@color/green_primary"
                                android:fontFamily="@font/sora_bold"
                                android:background="@drawable/bg_chip_green"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="7dp"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="♻️ Glass Bottle"
                                android:textSize="11.5sp"
                                android:textColor="@color/green_primary"
                                android:fontFamily="@font/sora_bold"
                                android:background="@drawable/bg_chip_green"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="7dp" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- ─────────────────────────────────────
                 CARD 4 · BRAND COMPARISON TABLE
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/view_section_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Info Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_info_banner"
                        android:orientation="horizontal"
                        android:padding="10dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="We compared ourselves with top brands so you can make the best choice for your family."
                            android:textSize="11.5sp"
                            android:textColor="@color/text_mid"
                            android:fontFamily="@font/sora_regular"
                            android:lineSpacingMultiplier="1.5" />
                    </LinearLayout>

                    <!-- Comparison Table (HorizontalScrollView for small screens) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:minWidth="340dp">

                            <!-- TABLE HEADER ROW -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:orientation="horizontal">

                                <!-- Feature Column Header -->
                                <TextView
                                    android:layout_width="110dp"
                                    android:layout_height="match_parent"
                                    android:text="Feature"
                                    android:textSize="10sp"
                                    android:textColor="@color/text_muted"
                                    android:fontFamily="@font/sora_bold"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.1"
                                    android:gravity="center_vertical"
                                    android:paddingStart="4dp" />

                                <!-- DoodhWala (OUR) Header -->
                                <LinearLayout
                                    android:layout_width="70dp"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_our_column_header"
                                    android:orientation="vertical"
                                    android:gravity="center"
                                    android:layout_marginEnd="2dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="DoodhWala"
                                        android:textSize="9sp"
                                        android:textColor="@color/white"
                                        android:fontFamily="@font/sora_bold"
                                        android:gravity="center" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="⭐ Ours"
                                        android:textSize="8sp"
                                        android:textColor="#CCffffff"
                                        android:fontFamily="@font/sora_regular"
                                        android:gravity="center" />
                                </LinearLayout>

                                <!-- Amul Header -->
                                <TextView
                                    android:layout_width="60dp"
                                    android:layout_height="match_parent"
                                    android:text="Amul"
                                    android:textSize="10sp"
                                    android:textColor="@color/text_muted"
                                    android:fontFamily="@font/sora_bold"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.08"
                                    android:gravity="center"
                                    android:background="@color/bg_screen" />

                                <!-- Mother Dairy Header -->
                                <TextView
                                    android:layout_width="70dp"
                                    android:layout_height="match_parent"
                                    android:text="Mother\nDairy"
                                    android:textSize="10sp"
                                    android:textColor="@color/text_muted"
                                    android:fontFamily="@font/sora_bold"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.08"
                                    android:gravity="center"
                                    android:background="@color/white" />

                                <!-- Nestle Header -->
                                <TextView
                                    android:layout_width="60dp"
                                    android:layout_height="match_parent"
                                    android:text="Nestle"
                                    android:textSize="10sp"
                                    android:textColor="@color/text_muted"
                                    android:fontFamily="@font/sora_bold"
                                    android:textAllCaps="true"
                                    android:letterSpacing="0.08"
                                    android:gravity="center"
                                    android:background="@color/bg_screen" />

                            </LinearLayout>

                            <!-- Divider below header -->
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="2dp"
                                android:background="@color/border_light" />

                            <!-- TABLE BODY — each row included from item_comparison_row -->
                            <!-- Row: A2 Protein -->
                            <include layout="@layout/item_comparison_row" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                            <!-- Row: Farm Fresh -->
                            <include layout="@layout/item_comparison_row" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                            <!-- Row: No Preservatives -->
                            <include layout="@layout/item_comparison_row" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                            <!-- Row: Hormone Free -->
                            <include layout="@layout/item_comparison_row" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                            <!-- Row: 100% Organic -->
                            <include layout="@layout/item_comparison_row" />
                            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border_light" />

                            <!-- Row: Price / 500ml -->
                            <include layout="@layout/item_comparison_row" />

                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✔ Yes"
                            android:textSize="10sp"
                            android:textColor="@color/green_mid"
                            android:fontFamily="@font/sora_bold" />

                        <View android:layout_width="1dp" android:layout_height="12dp"
                            android:layout_marginHorizontal="12dp"
                            android:background="@color/border_light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✘ No"
                            android:textSize="10sp"
                            android:textColor="#E04040"
                            android:fontFamily="@font/sora_bold" />

                        <View android:layout_width="1dp" android:layout_height="12dp"
                            android:layout_marginHorizontal="12dp"
                            android:background="@color/border_light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="~ Partial"
                            android:textSize="10sp"
                            android:textColor="#D4860A"
                            android:fontFamily="@font/sora_bold" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- ─────────────────────────────────────
                 CARD 5 · CUSTOMER REVIEWS
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <include layout="@layout/view_section_header"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvSeeAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See all →"
                            android:textSize="12sp"
                            android:textColor="@color/green_primary"
                            android:fontFamily="@font/sora_bold" />

                    </LinearLayout>

                    <!-- Rating Summary Box -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_rating_box"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <!-- Big Rating Number -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:id="@+id/tvRatingBig"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4.8"
                                android:textSize="36sp"
                                android:textColor="@color/text_dark"
                                android:fontFamily="@font/sora_bold" />

                            <!-- Stars Row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled" android:layout_marginEnd="1dp" android:contentDescription="Star" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled" android:layout_marginEnd="1dp" android:contentDescription="Star" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled" android:layout_marginEnd="1dp" android:contentDescription="Star" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled" android:layout_marginEnd="1dp" android:contentDescription="Star" />
                                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_half" android:contentDescription="Half Star" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="2,341 reviews"
                                android:textSize="10sp"
                                android:textColor="@color/text_muted"
                                android:fontFamily="@font/sora_regular" />

                        </LinearLayout>

                        <!-- Rating Bars -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- 5 star bar -->
                            <include layout="@layout/item_rating_bar" />
                            <!-- 4 star bar -->
                            <include layout="@layout/item_rating_bar" />
                            <!-- 3 star bar -->
                            <include layout="@layout/item_rating_bar" />
                            <!-- 2 star bar -->
                            <include layout="@layout/item_rating_bar" />
                            <!-- 1 star bar -->
                            <include layout="@layout/item_rating_bar" />

                        </LinearLayout>
                    </LinearLayout>

                    <!-- Review Cards (horizontal scroll) -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Review Item 1 -->
                            <include layout="@layout/item_review_card"
                                android:layout_width="220dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="10dp" />

                            <!-- Review Item 2 -->
                            <include layout="@layout/item_review_card"
                                android:layout_width="220dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="10dp" />

                            <!-- Review Item 3 -->
                            <include layout="@layout/item_review_card"
                                android:layout_width="220dp"
                                android:layout_height="wrap_content" />

                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- ─────────────────────────────────────
                 CARD 6 · DELIVERY INFO
            ───────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <include layout="@layout/view_section_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <!-- Delivery Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView android:layout_width="32dp" android:layout_height="32dp"
                            android:text="🚚" android:textSize="18sp" android:gravity="center" />

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="10dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Free Home Delivery"
                                android:textSize="13sp" android:textColor="@color/text_dark"
                                android:fontFamily="@font/sora_bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Delivered by 7:00 AM tomorrow"
                                android:textSize="11sp" android:textColor="@color/text_muted"
                                android:fontFamily="@font/sora_regular" />
                        </LinearLayout>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="FREE"
                            android:textSize="11sp" android:textColor="@color/green_primary"
                            android:fontFamily="@font/sora_bold"
                            android:background="@drawable/bg_chip_green"
                            android:paddingHorizontal="10dp" android:paddingVertical="5dp" />

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:layout_marginVertical="10dp" android:background="@color/border_light" />

                    <!-- Delivery Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView android:layout_width="32dp" android:layout_height="32dp"
                            android:text="↩️" android:textSize="18sp" android:gravity="center" />

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:layout_marginStart="10dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Easy Returns"
                                android:textSize="13sp" android:textColor="@color/text_dark"
                                android:fontFamily="@font/sora_bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Not satisfied? Return within 24 hours"
                                android:textSize="11sp" android:textColor="@color/text_muted"
                                android:fontFamily="@font/sora_regular" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <!-- ══════════════════════════════════════════
         BOTTOM STICKY — ADD TO CART
    ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingTop="10dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Wishlist -->
            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnWishlist"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_wishlist_btn"
                android:src="@drawable/ic_heart_outline"
                android:padding="12dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="Add to wishlist" />

            <!-- Add to Cart -->
            <Button
                android:id="@+id/btnAddToCart"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Add to Cart  ·  ₹65"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:fontFamily="@font/sora_bold"
                android:background="@drawable/bg_add_to_cart_btn"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
