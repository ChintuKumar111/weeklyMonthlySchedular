<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FFF7"
    android:overScrollMode="never"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── TOOLBAR ── -->

        <!-- ── HERO SCENE ── -->
        <LinearLayout
            android:id="@+id/llToolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/primary"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="33dp"
                android:layout_height="38dp"
                android:layout_gravity="center_vertical"
                android:layout_margin="@dimen/_5sdp"
                android:background="@drawable/bg_icon_btn_white_circle"
                android:contentDescription="Back"
                android:elevation="@dimen/_50sdp"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                android:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Vacation Mode"
                android:textColor="@color/white"
                android:textSize="19sp"
                android:textStyle="bold" />

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:clipChildren="false">

            <!-- Sky gradient background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_hero_sky" />

            <!-- Sun -->
            <ImageView
                android:id="@+id/ivSun"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="52dp"
                android:src="@drawable/ic_sun"
                android:contentDescription="Sun" />

            <!-- Cloud 1 -->
            <ImageView
                android:id="@+id/ivCloud1"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:layout_gravity="top|start"
                android:layout_marginTop="24dp"
                android:layout_marginStart="-10dp"
                android:src="@drawable/ic_cloud"
                android:alpha="0.9"
                android:contentDescription="Cloud" />

            <!-- Cloud 2 -->
            <ImageView
                android:id="@+id/ivCloud2"
                android:layout_width="70dp"
                android:layout_height="30dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="110dp"
                android:src="@drawable/ic_cloud"
                android:alpha="0.75"
                android:contentDescription="Cloud" />

            <!-- Cloud 3 -->
            <ImageView
                android:id="@+id/ivCloud3"
                android:layout_width="80dp"
                android:layout_height="35dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="36dp"
                android:layout_marginEnd="-5dp"
                android:src="@drawable/ic_cloud"
                android:alpha="0.85"
                android:contentDescription="Cloud" />

            <!-- Vacation Mode text (Pacifico style via custom font) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvHeroLine1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vacation"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#40005080"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="6" />

                <TextView
                    android:id="@+id/tvHeroLine2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mode 🏖️"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#40005080"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="6" />

            </LinearLayout>

<!--            &lt;!&ndash; Ocean &ndash;&gt;-->
<!--            <View-->
<!--                android:id="@+id/viewOcean"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="70dp"-->
<!--                android:layout_gravity="bottom"-->
<!--                android:layout_marginBottom="52dp"-->
<!--                android:background="@drawable/bg_ocean" />-->

            <!-- Wave overlay -->
<!--            <View-->
<!--                android:id="@+id/viewWave"-->
<!--                android:layout_width="match_parent"-->
