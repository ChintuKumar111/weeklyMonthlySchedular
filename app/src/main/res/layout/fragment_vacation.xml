            <!-- Section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Vacation"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A2F3A"
                android:layout_marginBottom="12dp"
                />

            <!-- Date pickers row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Start Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="START DATE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#4A6572"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="5dp"
                        />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvStartDate"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center_vertical"
                            android:paddingStart="36dp"
                            android:paddingEnd="12dp"
                            android:text="Select Date"
                            android:textSize="13sp"
                            android:textColor="#8FA9B5"
                            android:background="@drawable/bg_date_field"
                            />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/ic_calendar"
                            android:tint="#8FA9B5"
                            android:contentDescription="Calendar" />

                    </FrameLayout>

                </LinearLayout>

                <!-- End Date -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="END DATE"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#4A6572"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="5dp"
                        />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvEndDate"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:gravity="center_vertical"
                            android:paddingStart="36dp"
                            android:paddingEnd="12dp"
                            android:text="Select Date"
                            android:textSize="13sp"
                            android:textColor="#8FA9B5"
                            android:background="@drawable/bg_date_field"
                            />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/ic_calendar"
                            android:tint="#8FA9B5"
                            android:contentDescription="Calendar" />

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Duration Pill (gone by default) -->
            <LinearLayout
                android:id="@+id/llDurationPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_duration_pill"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ "
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A9FD4"
                    />

            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnStartVacation"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:text="🏖️  Start Vacation"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_btn_primary"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

                <Button
                    android:id="@+id/btnClearVacation"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Clear Vacation"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:background="@drawable/bg_btn_outline"
                    app:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:elevation="0dp" />

            </LinearLayout>

            <!-- Previous Vacations Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Previous Vacations"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A2F3A"
                android:layout_marginBottom="12dp"
                 />

            <!-- Previous Vacations List container -->
            <LinearLayout
                android:id="@+id/llVacationHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/llEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="24dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="No previous vacations"
                    android:textSize="14sp"
                    android:textColor="#8FA9B5"
                   />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>