<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/cartFragment"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ═══════════════════════════════════════ -->
    <!--              HEADER SECTION             -->
    <!-- ═══════════════════════════════════════ -->

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:liftOnScroll="false"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="8dp"
            app:titleTextColor="@color/white"
            android:background="@color/primary"
            app:title="@string/my_cart"
            app:titleTextAppearance="@style/ToolbarTitleStyle" />

    </com.google.android.material.appbar.AppBarLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/animEmptyCart"
        android:layout_width="@dimen/_150sdp"
        android:layout_height="@dimen/_250sdp"
        app:lottie_rawRes="@raw/empty"
        app:lottie_loop="true"
        android:visibility="gone"
        app:lottie_autoPlay="true"
        android:layout_gravity="center"
        />

    <TextView
        android:id="@+id/tvCartIsEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="@font/sora_bold"
        android:text="@string/cart_empty"/>


    <TextView
        android:id="@+id/tvFreshness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_5sdp"
        android:fontFamily="@font/sora_regular"
        android:visibility="gone"
        android:text="@string/fill_freshness"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShopNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:text="@string/shop_now"
        android:visibility="gone"
        app:cornerRadius="@dimen/_5sdp"
        android:backgroundTint="@color/primary"
        android:layout_gravity="center_horizontal"/>
        <!-- ═══════════════════════════════════════ -->
    <!--           SCROLLABLE CONTENT            -->
    <!-- ═══════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llElements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Delivery Date Row -->
            <RelativeLayout
                android:id="@+id/layoutDateSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="13dp"
                android:background="@drawable/date_selector_bg"
                android:clickable="true"
                android:layout_marginBottom="@dimen/_5sdp"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="19sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="February 24, 2026"
                            android:textColor="#1a1a2e"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDeliveryBegins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/delivery_begins"
                            android:textColor="#6B7280"
                            android:textSize="10sp"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                </LinearLayout>

                <ImageView
                    android:id="@+id/btnEditDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Edit"
                    android:src="@drawable/baseline_edit_24"
                    android:tint="@color/primary" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Section Label -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/items_in_cart"
                    android:textSize="11sp"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textColor="#7A7A7A"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Item Count Badge -->
                <TextView
                    android:id="@+id/tvItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 items"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />

            </LinearLayout>
            <!-- ─────────────────────────────── -->
            <!--       CART ITEM 1               -->
            <!-- ─────────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/rvAddedProductInCart"/>



            <!--           PRICE DETAILS CARD            -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPriceDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                android:layout_marginTop="@dimen/_80sdp"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginEnd="@dimen/_5sdp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"

                    android:padding="10dp">

                    <!-- Card Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_details"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="@dimen/_5sdp" />

                    <!-- Total MRP Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total_mrp"
                            android:textSize="10sp"
                            android:textColor="#7A7A7A" />

                        <TextView
                            android:id="@+id/tvTotalMRP"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹310.00"
                            android:textSize="13sp"
                            android:textStyle="normal"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E8E4DC" />

                    <!-- Discount Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total_discount"
                            android:textSize="10sp"
                            android:textColor="#7A7A7A" />

                        <TextView
                            android:id="@+id/tvDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="−₹25.00"
                            android:textSize="13sp"
                            android:textStyle="normal"
                            android:textColor="#1A7A4A" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E8E4DC" />

                    <!-- Delivery Fee Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/delivery_fee"
                            android:textSize="10sp"
                            android:textColor="#7A7A7A" />

                        <TextView
                            android:id="@+id/tvDeliveryFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/free"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A7A4A" />
                    </LinearLayout>

                    <!-- Thick Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#E8E4DC"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                    <!-- Total Payable Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total_payable"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:id="@+id/tvTotalPayable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹285"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Savings Pill -->
            <TextView
                android:id="@+id/tvSavings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_green_light_rounded"
                android:gravity="center"
                android:padding="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="@string/savings_msg"
                android:textColor="@color/primary"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>


    <!-- ═══════════════════════════════════════ -->
    <!--              FOOTER SECTION             -->
    <!-- ═══════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_5sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        >



        <!-- Order Button -->

        <!-- ══════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubscribeNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text="@string/place_order"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:backgroundTint="@color/primary"
            android:background="@drawable/btn_cta_green"
            android:elevation="8dp" />

    </FrameLayout>


    <!-- ═══════════════════════════════════════ -->
    <!--            BOTTOM NAVIGATION            -->
    <!-- ═══════════════════════════════════════ -->

</LinearLayout>