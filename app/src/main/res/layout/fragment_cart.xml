<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/cartFragment"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ═══════════════════════════════════════ -->
    <!--              HEADER SECTION             -->
    <!-- ═══════════════════════════════════════ -->

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:liftOnScroll="false"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="8dp"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_back"
            android:background="@color/primary"
            app:title="My Cart"
            app:titleTextAppearance="@style/ToolbarTitleStyle" />

    </com.google.android.material.appbar.AppBarLayout>


    <!-- ═══════════════════════════════════════ -->
    <!--           SCROLLABLE CONTENT            -->
    <!-- ═══════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Delivery Date Row -->
            <RelativeLayout
                android:id="@+id/layoutDateSelector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="13dp"
                android:background="@drawable/date_selector_bg"
                android:clickable="true"
                android:layout_marginBottom="@dimen/_5sdp"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="19sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:id="@+id/tvSelectedDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="February 24, 2026"
                            android:textColor="#1a1a2e"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDeliveryBegins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Delivery begins Tuesday"
                            android:textColor="#6B7280"
                            android:textSize="10sp"
                            android:layout_marginTop="1dp" />

                    </LinearLayout>

                </LinearLayout>

                <ImageView
                    android:id="@+id/btnEditDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Edit"
                    android:src="@drawable/baseline_edit_24"
                    android:tint="@color/primary" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Section Label -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="ITEMS IN CART"
                    android:textSize="11sp"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:textColor="#7A7A7A"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Item Count Badge -->
                <TextView
                    android:id="@+id/tvItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 items"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_badge_green"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />



            </LinearLayout>




            <!-- ─────────────────────────────── -->
            <!--       CART ITEM 1               -->
            <!-- ─────────────────────────────── -->

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/rvAddedProductInCart"/>



            <!--           PRICE DETAILS CARD            -->
            <!-- ═══════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPriceDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card Title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price Details"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="@dimen/_5sdp" />

                    <!-- Total MRP Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total MRP"
                            android:textSize="13sp"
                            android:textColor="#7A7A7A" />

                        <TextView
                            android:id="@+id/tvTotalMRP"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹310.00"
                            android:textSize="13sp"
                            android:textStyle="normal"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E8E4DC" />

                    <!-- Discount Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Discount"
                            android:textSize="13sp"
                            android:textColor="#7A7A7A" />

                        <TextView
                            android:id="@+id/tvDiscount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="−₹25.00"
                            android:textSize="13sp"
                            android:textStyle="normal"
                            android:textColor="#1A7A4A" />
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E8E4DC" />

                    <!-- Delivery Fee Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Delivery Fee"
                            android:textSize="13sp"
                            android:textColor="#7A7A7A" />

                        <TextView
                            android:id="@+id/tvDeliveryFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FREE 🎉"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A7A4A" />
                    </LinearLayout>

                    <!-- Thick Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#E8E4DC"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp" />

                    <!-- Total Payable Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Payable"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:id="@+id/tvTotalPayable"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹285"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="serif"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Savings Pill -->
            <TextView
                android:id="@+id/tvSavings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_green_light_rounded"
                android:gravity="center"
                android:padding="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:text="🎊 You're saving ₹25 on this order!"
                android:textColor="@color/primary"
                android:textSize="12sp" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════ -->
    <!--              FOOTER SECTION             -->
    <!-- ═══════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:elevation="8dp">


        <!-- Order Button -->

        <!-- ══════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubscribeNow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text="Place Order "
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            android:background="@drawable/btn_cta_green"
            android:elevation="8dp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════ -->
    <!--            BOTTOM NAVIGATION            -->
    <!-- ═══════════════════════════════════════ -->

</LinearLayout>