<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_day_row.xml -->
<!-- Reusable row: [toggle checkbox] [day name] [− qty +] [price] -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Toggle Checkbox -->
    <FrameLayout
        android:id="@+id/dayToggle"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:background="@drawable/day_toggle_off"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/ivDayCheck"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_circle"
            android:tint="@color/white"
            android:visibility="gone"
            android:contentDescription="Selected" />

    </FrameLayout>

    <!-- Day Name -->
    <TextView
        android:id="@+id/tvDayName"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/dayToggle"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:text="Mon"
        android:textColor="#1a1a2e"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- Price per day -->
    <TextView
        android:id="@+id/tvDayPrice"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:text="—"
        android:textColor="#6B7280"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="end" />

    <!-- Mini Stepper -->
    <LinearLayout
        android:id="@+id/miniStepper"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/tvDayPrice"
        android:layout_centerVertical="true"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        android:background="@drawable/stepper_bg"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnDayMinus"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_minus"
            android:tint="@color/primary"
            android:contentDescription="Decrease" />

        <TextView
            android:id="@+id/tvDayQty"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#1a1a2e"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnDayPlus"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_plus"
            android:tint="@color/primary"
            android:contentDescription="Increase" />

    </LinearLayout>

</RelativeLayout>