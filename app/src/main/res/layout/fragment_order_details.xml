<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5F2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════════════════════════════
             HEADER
        ══════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:tint="@color/black"
                android:background="@drawable/bg_btn_circle"
                android:src="@drawable/ic_back"
                android:padding="10dp"
                android:contentDescription="Back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order Details"
                android:textSize="16sp"
                android:textColor="#1A1A1A"
                android:textStyle="bold"
                android:layout_marginStart="10dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Delivered"
                android:textSize="12sp"
                android:textColor="#2D6A4F"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_green"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- ══════════════════════════════
             PRODUCT CARD
        ══════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="5dp">

                <!-- Product Image Placeholder -->
                <ImageView
                    android:id="@+id/imgProduct"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_active_badge"
                    android:src="@drawable/ghee"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:contentDescription="Product Image" />

                <!-- Product Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FreshyZo Ghee"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500ml  ·  Qty: 1  ·  #4559"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:layout_marginTop="3dp" />

                </LinearLayout>

<!--                &lt;!&ndash; Price &ndash;&gt;-->
<!--                <TextView-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="₹450"-->
<!--                    android:textSize="18sp"-->
<!--                    android:textColor="#2D6A4F"-->
<!--                    android:textStyle="bold" />-->

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- ══════════════════════════════
             PRICE BREAKDOWN
        ══════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRICE BREAKDOWN"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- Subtotal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Subtotal"
                        android:textSize="12sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹45" android:textSize="12sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                <!-- GST -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="GST"
                        android:textSize="12sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹0" android:textSize="12sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                <!-- Delivery Fee -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Delivery Fee"
                        android:textSize="12sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹0.00" android:textSize="12sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                <!-- Total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp">

                    <TextView android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Paid"
                        android:textSize="12sp"
                        android:textColor="#1A1A1A"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹450"
                        android:textSize="14sp"
                        android:textColor="#2D6A4F"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════
             ORDER INFO
        ══════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORDER INFO"
                    android:textSize="11sp"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="8dp" />

                <!-- Order ID -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingTop="7dp" android:paddingBottom="7dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Order ID"
                        android:textSize="13sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#4559" android:textSize="13sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                <!-- Ordered -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingTop="7dp" android:paddingBottom="7dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Ordered"
                        android:textSize="13sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Jan 30, 2026" android:textSize="13sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                <!-- Delivered -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingTop="7dp" android:paddingBottom="7dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Delivered"
                        android:textSize="13sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Jan 31, 2026" android:textSize="13sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EBEBEB" />

                <!-- Payment -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingTop="7dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Payment"
                        android:textSize="13sp" android:textColor="#888888" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="UPI" android:textSize="13sp" android:textColor="#1A1A1A" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════
             ACTION BUTTONS
        ══════════════════════════════ -->

        <!-- Need Help Button -->
        <Button
            android:id="@+id/btnHelp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Need Help?"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_green"
            android:layout_marginBottom="10dp" />

        <!-- Cancel Order Button -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cancel Order"
            android:textSize="14sp"
            android:textColor="#D62828"
            android:textStyle="bold"
            android:background="@drawable/badge_green_light"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>