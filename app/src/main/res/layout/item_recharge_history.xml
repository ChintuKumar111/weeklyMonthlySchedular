<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_recharge_history.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_color"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Icon -->
        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center" android:layout_marginEnd="14dp">

            <ImageView
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:src="@drawable/check_history"
                 />
        </LinearLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wallet Recharge"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/sora_bold" />

            <TextView
                android:id="@+id/tvHistoryDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24 Feb 2026 • 9:41 AM"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:fontFamily="@font/sora_regular"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Amount + Status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvHistoryAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+₹1,000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary"
                android:fontFamily="@font/sora_extrabold" />

            <TextView
                android:id="@+id/tvHistoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Success"
                android:textSize="11sp"
                android:textColor="@color/green_primary"
                android:fontFamily="@font/sora_bold"
                android:background="@drawable/bg_status_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>