<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_preview_invoice_section.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="9dp"
    android:paddingEnd="12dp"
    android:paddingBottom="9dp">

    <TextView
        android:id="@+id/tvRowSrNo"
        android:layout_width="30dp"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRowDate"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="2dp"
        android:textColor="#555555"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/tvRowTransaction"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="2dp"
        android:textColor="#111111"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRowQty"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#333333"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvRowSale"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="#333333"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvRowRecharge"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/black"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tvRowBalance"
        android:layout_width="80dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textSize="11sp"
        android:textStyle="bold" />

</LinearLayout>