<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/deliveryCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/card_bg"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_5sdp"
        android:layout_marginEnd="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_2sdp"
        android:orientation="vertical">

        <!-- Top glow accent line -->
        <View
            android:id="@+id/cardGlowLine"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:visibility="gone"
            android:background="@drawable/gradient_glow_green" />

        <!-- Card Head: Image + Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="5dp"
            android:paddingBottom="12dp">

            <!-- Product Image Box -->

            <FrameLayout
                android:id="@+id/productImageBox"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_product_image_milk">

                <TextView
                    android:id="@+id/tvProductEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🥛"
                    android:textSize="32sp" />

            </FrameLayout>

            <!-- Product Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">



                <!-- Product Name -->
                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:text="A2 Cow Milk"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />



                <!-- Brand Name -->
                <TextView
                    android:id="@+id/tvBrandName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FreshyZo Premium"
                    android:textColor="@color/primary_dark"
                    android:textSize="11sp"
                    android:visibility="gone"
                    android:layout_marginTop="5dp" />

                <!-- Tags Row: TxnID | Size | Qty -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="7dp">

                    <TextView
                        android:id="@+id/tvSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500 ml"
                        android:textColor="@color/emerald"
                        android:textSize="10sp"
                        android:textStyle="normal"
                        android:background="@drawable/bg_tag_green"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvQty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="×2 units"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp"
                        android:textStyle="normal"
                        android:background="@drawable/bg_tag_dark"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp" />


                </LinearLayout>

            </LinearLayout>
            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Placed"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_gravity="end"
                android:textColor="@color/emerald"
                android:background="@drawable/bg_badge_placed"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="6dp"
                android:letterSpacing="0.03" />
        </LinearLayout>

        <!-- Card Footer: Date + Remark -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="@dimen/_5sdp"
            android:paddingStart="18dp">

            <!-- Date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/calendar"
                    android:alpha="0.7"
                    android:layout_marginEnd="5dp"
                    android:contentDescription="Date" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Feb 26, 2026"
                    android:textColor="@color/gray_900"
                    android:textSize="11sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="@dimen/_5sdp"
                android:background="@drawable/bg_tag_dark"
                android:orientation="horizontal">


                <!-- Remark Chip -->
                <TextView
                    android:id="@+id/tvRemark"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More details"
                    android:textColor="@color/primary_dark"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="10dp"
                    android:layout_gravity="center"
                    android:tint="@color/primary_dark"
                    android:src="@drawable/outline_arrow_forward_ios_24"/>

            </LinearLayout>



        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>