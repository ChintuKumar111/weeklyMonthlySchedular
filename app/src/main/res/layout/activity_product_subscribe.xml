<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <!-- ══════════════════════════════════════ -->
        <!--              HEADER                    -->
        <!-- ══════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="0dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:tint="@color/black"
                android:background="@drawable/bg_btn_circle"
                android:src="@drawable/ic_back"
                android:padding="10dp"
                android:layout_gravity="center_vertical"
                android:contentDescription="Back" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView"
                android:layout_width="@dimen/_130sdp"
                android:layout_height="@dimen/_130sdp"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="@dimen/_30sdp"
                app:cardCornerRadius="@dimen/_12sdp">

                <ImageView
                    android:id="@+id/ivProductImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Product Image"
                    android:scaleType="centerCrop"
                    android:src="@drawable/milk_" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvBrandTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/btnBack"
                android:layout_marginTop="@dimen/_12sdp"
                android:text="FRESHYZO · FRESH DAILY"
                android:textColor="#5BD4F4"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProductTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvBrandTag"
                android:layout_alignParentStart="true"
                android:layout_marginTop="4dp"
                android:layout_toStartOf="@+id/cardView"
                android:lineSpacingMultiplier="1.1"
                android:text="Buffalo Milk\n1000 ml"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutPriceRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvProductTitle"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPriceMain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹70"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPriceOld"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="₹75.00"
                    android:textColor="@color/black"
                    android:textSize="12sp"

                     />

                <TextView
                    android:id="@+id/tvOffBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="6% OFF"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/badge_white_outline" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvInStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/cardView"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="@dimen/_2sdp"
                android:text="● In Stock"
                android:textColor="#E0FFE8"
                android:textSize="11sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <!-- ══════════════════════════════════════ -->
        <!--           PRODUCT IMAGE                -->
        <!-- ══════════════════════════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1DB954">


            <!-- gradient fade into content below -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/_1sdp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_green_to_cream" />

        </FrameLayout>

        <!-- ══════════════════════════════════════ -->
        <!--       DELIVERY FREQUENCY CARD          -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <!-- ── Label ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELIVERY FREQUENCY"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- ── 4 Chips in one row ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- DAILY -->
                    <LinearLayout
                        android:id="@+id/optionDaily"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp"
                        android:background="@drawable/freq_option_selected"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvDailyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily"
                            android:textColor="#2E7D32"
                            android:textSize="10sp"
                            android:textStyle="bold" />


                    </LinearLayout>

                    <!-- ALTERNATE DAYS -->
                    <LinearLayout
                        android:id="@+id/optionAlternate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp"
                        android:background="@drawable/freq_option_default"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvAlternateTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alt Days"
                            android:textColor="#1a1a2e"
                            android:textSize="10sp"
                            android:textStyle="bold" />



                    </LinearLayout>

                    <!-- WEEKLY -->
                    <LinearLayout
                        android:id="@+id/optionWeekly"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="4dp"
                        android:background="@drawable/freq_option_default"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/tvWeeklyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly"
                            android:textColor="#1a1a2e"
                            android:textSize="10sp"
                            android:textStyle="bold" />



                    </LinearLayout>

<!--                    &lt;!&ndash; MONTHLY &ndash;&gt;-->
<!--                    <LinearLayout-->
<!--                        android:id="@+id/optionMonthly"-->
<!--                        android:layout_width="0dp"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:layout_weight="1"-->
<!--                        android:orientation="vertical"-->
<!--                        android:gravity="center"-->
<!--                        android:visibility="gone"-->
<!--                        android:paddingVertical="10dp"-->
<!--                        android:paddingHorizontal="4dp"-->
<!--                        android:background="@drawable/freq_option_default"-->
<!--                        android:clickable="true"-->
<!--                        android:focusable="true">-->

<!--                        <TextView-->
<!--                            android:id="@+id/tvMonthlyTitle"-->
<!--                            android:layout_width="wrap_content"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:text="Monthly"-->
<!--                            android:textColor="#1a1a2e"-->
<!--                            android:textSize="10sp"-->
<!--                            android:textStyle="bold" />-->


<!--                    </LinearLayout>-->

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <!-- ══════════════════════════════════════ -->
        <!--           START DATE CARD              -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="START DATE"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:layout_marginBottom="10dp" />

                <RelativeLayout
                    android:id="@+id/layoutDateSelector"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="13dp"
                    android:background="@drawable/date_selector_bg"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/tvMonthDate"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/calendar" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/tvSelectedDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="February 24, 2026"
                                android:textColor="#1a1a2e"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvDeliveryBegins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Delivery begins Tuesday"
                                android:textColor="#6B7280"
                                android:textSize="10sp"
                                android:layout_marginTop="1dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnEditDate"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/baseline_edit_24"
                        android:tint="@color/primary"
                        android:contentDescription="Edit" />

                </RelativeLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--    DAY-WISE QUANTITY CARD              -->
        <!--    Visible only for Weekly   -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDayQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvDayQtyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="SELECT DAYS &amp; QUANTITY"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.10" />

                    <TextView
                        android:id="@+id/tvDayQtySummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="0 packets/week"
                        android:textColor="#17A349"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="3dp"
                        android:background="@drawable/badge_green_light" />

                </RelativeLayout>

                <!-- ── MONDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowMonday" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" />

                <!-- ── TUESDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowTuesday" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" />

                <!-- ── WEDNESDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowWednesday" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" />

                <!-- ── THURSDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowThursday" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" />

                <!-- ── FRIDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowFriday" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" />

                <!-- ── SATURDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowSaturday" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3F4F6" android:layout_marginTop="2dp" android:layout_marginBottom="2dp" />

                <!-- ── SUNDAY ── -->
                <include layout="@layout/item_day_row"
                    android:id="@+id/rowSunday" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!--         INTERVAL OPTIONS CARD          -->
        <!-- Visible only for Weekly/Alternate modes-->
        <!-- ══════════════════════════════════════ -->

        <!-- Visible only for Alternate modes-->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardIntervalOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DELIVER"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:layout_marginBottom="12dp" />

            <!-- Use a RadioGroup for single selection -->
            <RadioGroup
                android:id="@+id/radioGroupInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioEveryDay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_dark"
                    android:text="Every Day"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/radioEveryAlternateDay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_dark"
                    android:text="Every Alternate Day" />

                <RadioButton
                    android:id="@+id/radioEvery2Days"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_dark"
                    android:text="Every 2 Days" />

                <RadioButton
                    android:id="@+id/radioEvery3Days"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_dark"
                    android:text="Every 3 Days" />
            </RadioGroup>

        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <!-- ══════════════════════════════════════ -->
        <!--    SIMPLE QUANTITY CARD                -->
        <!--    Visible only for Daily / Monthly    -->
        <!-- ══════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSimpleQty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUANTITY"
                    android:textColor="#6B7280"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:layout_marginBottom="5dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/layoutQtyLabels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Packets per delivery"
                            android:textColor="#1a1a2e"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvQtySub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 packet × daily"
                            android:textColor="#6B7280"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="horizontal"
                        android:background="@drawable/stepper_bg"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btnQtyMinus"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Decrease"
                            android:src="@drawable/ic_minus"
                            android:tint="@color/gray_900" />

                        <TextView
                            android:id="@+id/tvQtyValue"
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textColor="#1a1a2e"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <ImageButton
                            android:id="@+id/btnQtyPlus"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_plus"
                            android:tint="@color/primary"
                            android:contentDescription="Increase" />

                    </LinearLayout>

                </RelativeLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════════════════════════════════ -->
        <!--           PRICE SUMMARY CARD           -->
        <!-- ══════════════════════════════════════ -->


        <!-- ══════════════════════════════════════ -->
        <!--           INFO BANNER                  -->
        <!-- ══════════════════════════════════════ -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg"
                android:backgroundTint="@color/white"
                android:orientation="vertical"
                android:padding="10dp">

                <!-- ── Header Row ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.05"
                        android:text="MONTHLY PRICE SUMMARY"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ── Price per packet ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Price per packet"
                        android:textColor="#5A7A65"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvPricePerPacket"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹89"
                        android:textColor="#1A2E20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ── Packets per delivery ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Packets"
                        android:textColor="#5A7A65"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvPackets"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textColor="#1A2E20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ── Deliveries/month ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Deliveries"
                        android:textColor="#5A7A65"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tvDeliveriesPerMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30 days"
                        android:textColor="#1A2E20"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- ── Divider ── -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="2dp"
                    android:background="#DDEEE5" />

                <!-- ── Total / Month Row ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_total_row"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total"
                        android:textColor="#1A2E20"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvTotalMonthly"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹4,005"
                        android:textColor="#27AE60"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </LinearLayout>


            </LinearLayout>
        </androidx.cardview.widget.CardView>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:padding="14dp"
            android:visibility="gone"
            android:background="@drawable/info_banner_bg"
            android:orientation="horizontal">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ℹ️" android:textSize="15sp" android:layout_marginTop="1dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Your subscription delivery will begin on Tuesday, 24th February. You can pause or cancel anytime from your account."
                android:textColor="#92400E"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--           OFFER CARD                   -->
        <!-- ══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="14dp"
            android:padding="16dp"
            android:background="@drawable/offer_card_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/offer_icon_bg">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🏷️" android:textSize="21sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Subscription Offer Applied" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Flat 25% off + Up to 30 packets FREE on 1st recharge" android:textColor="#99FFFFFF" android:textSize="10sp" android:layout_marginTop="3dp" android:lineSpacingMultiplier="1.3" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="✓ Applied"
                android:textColor="#1DB954"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/badge_green_light" />

        </LinearLayout>

        <!-- ══════════════════════════════════════ -->
        <!--              CTA BUTTON                -->
        <!-- ══════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubscribeNow"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_40sdp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:text="Subscribe Now "
            android:textColor="@color/white"
            android:layout_gravity="bottom"
            android:textSize="@dimen/_12sdp"
            android:textStyle="bold"
            app:cornerRadius="@dimen/_15sdp"
            app:backgroundTint="@color/primary"
            android:background="@drawable/btn_cta_green"
            android:elevation="8dp" />

    </LinearLayout>
</ScrollView>
