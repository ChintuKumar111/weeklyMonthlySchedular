<?xml version="1.0" encoding="utf-8"?>
<!-- item_product_card.xml  — used in rvProducts RecyclerView -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/border_light"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Image + Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Product Image + Badge -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:elevation="@dimen/_3sdp"
                    app:cardCornerRadius="@dimen/_10sdp"
                    android:layout_height="match_parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProduct"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        />

                </androidx.cardview.widget.CardView>

                <!-- Small pack badge -->
                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_badge_green"
                    android:text="A2"
                    android:textColor="@color/white"
                    android:textSize="9sp"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />

            </FrameLayout>

            <!-- Product Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!-- Tag (e.g. "100% Natural") -->
                <TextView
                    android:id="@+id/tvTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100% Natural"
                    android:textColor="@color/green_primary"
                    android:textSize="10sp"
                    android:letterSpacing="0.05"
                    android:textAllCaps="true" />

                <!-- Product Name -->
                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="FreshyZo A2 Cow Milk"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:lineSpacingMultiplier="1.2" />

                <!-- Price Row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹45"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                         />

                    <TextView
                        android:id="@+id/tvOriginalPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="₹50"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="10% OFF"
                        android:background="@drawable/bg_discount_badge"
                        android:textColor="@color/orange_primary"
                        android:textSize="10sp"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp" />

                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:id="@+id/tvDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:visibility="gone"
                    android:text="Pure, digestible &amp; healthy"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />

                <!-- Size chip -->
                <TextView
                    android:id="@+id/tvSize1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="500ml"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_size_chip_active"
                    android:textColor="@color/green_primary"
                    android:textSize="8dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:layout_marginTop="@dimen/_3sdp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Actions (Qty + Add + Subscribe) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="end">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/_5sdp">

                <!-- Buy Now Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdd"
                    android:layout_width="90dp"
                    android:layout_height="match_parent"
                    android:text="ADD"
                    android:textColor="@color/green_primary"
                    android:textSize="12sp"
                    android:padding="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/green_primary"
                    app:strokeWidth="1dp"
                    android:backgroundTint="@color/white"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                <!-- Quantity Control -->
                <LinearLayout
                    android:id="@+id/llQtyCtrl"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:visibility="gone"
                    android:background="@drawable/bg_qty_ctrl">

                    <TextView
                        android:id="@+id/tvMinus"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:text="−"
                        android:textColor="@color/green_primary"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvQty"
                        android:layout_width="30dp"
                        android:layout_height="match_parent"
                        android:text="1"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvPlus"
                        android:layout_width="32dp"
                        android:layout_height="match_parent"
                        android:text="+"
                        android:textColor="@color/green_primary"
                        android:textSize="20sp"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

            </FrameLayout>

            <!-- Subscribe -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubscribe"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:padding="@dimen/_3sdp"
                android:paddingStart="@dimen/_11sdp"
                android:paddingEnd="@dimen/_11sdp"
                android:text="Subscribe"
                android:gravity="center"
                android:textColor="@color/white"
                app:backgroundTint="@color/primary"
                app:cornerRadius="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
