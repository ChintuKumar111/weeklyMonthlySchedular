<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:id="@+id/cardItem1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white"
    android:layout_marginBottom="10dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/imgProduct1"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:src="@drawable/dahi"
            android:background="@drawable/bg_green_light_rounded_small"
            android:scaleType="centerCrop"
            android:contentDescription="Buffalo Milk" />

        <!-- Product Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp">

            <TextView
                android:id="@+id/tvName1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FreshyZo Buffalo Milk"
                android:textSize="13.5sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp" />

            <!-- Price Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="3dp">

                <!-- Discount Badge -->
                <TextView
                    android:id="@+id/tvDiscount1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7% OFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#5A4000"
                    android:background="@drawable/bg_badge_amber"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="6dp" />

                <!-- Original Price -->
                <TextView
                    android:id="@+id/tvOrigPrice1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹75"
                    android:textSize="11sp"
                    android:textColor="#7A7A7A"
                    android:layout_marginEnd="4dp" />

                <!-- Final Price -->
                <TextView
                    android:id="@+id/tvFinalPrice1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹70"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A7A4A" />

            </LinearLayout>

            <!-- Volume -->
            <TextView
                android:id="@+id/tvVolume1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1000 ml"
                android:textSize="11sp"
                android:textColor="#7A7A7A" />

        </LinearLayout>

        <!-- Quantity Control -->
        <LinearLayout
            android:id="@+id/layoutQty1"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/_5sdp"
            android:paddingEnd="@dimen/_5sdp"
            android:background="@drawable/bg_green_rounded_qty">

            <ImageButton
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Increase"
                android:scaleType="centerInside"
                android:padding="3dp"
                android:src="@drawable/ic_minus"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvQty1"
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnPlus1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_plus"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"
                android:scaleType="centerInside"
                android:padding="2dp"
                android:contentDescription="Increase" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>