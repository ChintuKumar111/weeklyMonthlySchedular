<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    >

    <!-- ═══════════════════════════════════════ -->
    <!--              HEADER SECTION             -->
    <!-- ═══════════════════════════════════════ -->

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:liftOnScroll="false"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="22dp"
            app:title="Account"
            app:titleTextAppearance="@style/ToolbarTitleStyle" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Hero Banner -->
            <include layout="@layout/layout_account_hero" />

            <!-- Quick Access Row -->
            <include layout="@layout/layout_quick_access" />

            <!-- Account & Setting Card Group -->

            <include layout="@layout/layout_account_card_group" />

            <!-- Support  & Info Card Group -->
            <include layout="@layout/layout_support_card_group" />

            <!-- Footer Links -->
            <include layout="@layout/layout_footer_links" />

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:background="@drawable/bg_outline_green"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                app:backgroundTint="#D6E04040"
                android:paddingTop="@dimen/_2sdp"
                android:paddingBottom="@dimen/_2sdp"
                app:icon="@drawable/logout"
                android:text="@string/log_out"
                android:layout_gravity="center_horizontal"
                app:iconGravity="textEnd"
                app:iconPadding="8dp" />

            <!-- App Info -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:text="@string/app_info"
                android:textAppearance="@style/AppInfoStyle" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>