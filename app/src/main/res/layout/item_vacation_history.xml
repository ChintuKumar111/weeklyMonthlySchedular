<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Icon -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_vcard_icon"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tvVCardIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌴"
                android:textSize="22sp" />

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvVCardDates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jan 5 – Jan 14, 2026"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1A2F3A"
                />

            <TextView
                android:id="@+id/tvVCardDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="9 days · 3 subscriptions paused"
                android:textSize="12sp"
                android:textColor="#8FA9B5"
                />

        </LinearLayout>

        <!-- Badge -->
        <TextView
            android:id="@+id/tvVCardBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:background="@drawable/bg_badge_done"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            />

    </LinearLayout>
</androidx.cardview.widget.CardView>