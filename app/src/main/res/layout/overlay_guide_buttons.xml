<?xml version="1.0" encoding="utf-8"?>
<!--
    res/layout/overlay_guide_buttons.xml
    Floated above the TapTargetView spotlight overlay.
    Injected programmatically into the DecorView by AppGuideManager.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <!-- Skip — outlined, less prominent -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuideSkip"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"
        android:layout_weight="1"
        android:text="Skip"
        android:textColor="@android:color/white"
        app:strokeColor="@android:color/white"
        app:strokeWidth="1.5dp"
        app:cornerRadius="24dp" />

    <!-- Continue — filled, primary action -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuideContinue"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="Continue"
        app:backgroundTint="@color/primary"
        app:cornerRadius="24dp" />

</LinearLayout>