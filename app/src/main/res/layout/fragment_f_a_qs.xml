<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════
         COLLAPSING HEADER
    ══════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/primary"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed|snap"
            app:contentScrim="@color/primary"
            app:title="FreshyZo Support"
            app:collapsedTitleTextColor="@color/white"
            app:titleEnabled="true"
            app:collapsedTitleTextAppearance="@style/CollapsedToolbarTitle"
            app:expandedTitleTextColor="@android:color/transparent">

            <!-- Green gradient background -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_faq_header"
                app:layout_collapseMode="parallax" />

            <!-- Decorative orb top-right -->
            <View
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-30dp"
                android:background="@drawable/bg_header_orb"
                app:layout_collapseMode="parallax" />

            <!-- Header text content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginBottom="60dp"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                app:layout_collapseMode="parallax">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FRESHYZO SUPPORT"
                    android:textSize="10sp"
                    android:textColor="@color/gray_200"
                    android:textAllCaps="true"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How can we help you? 🤝"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.15"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Answers to the most common questions\nabout products, delivery &amp; subscriptions."
                    android:textSize="11.5sp"
                    android:textColor="#AAFFFFFF"
                    android:fontFamily="@font/sora_regular"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Toolbar (back + title) — pinned on collapse -->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_gravity="top"
                app:layout_collapseMode="pin"
                app:contentInsetStart="0dp">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="12dp"
                    android:tint="@color/white"
                    android:background="@drawable/bg_icon_btn_white_circle"
                    android:src="@drawable/outline_arrow_back_24"
                    android:padding="9dp"
                    android:contentDescription="Back" />

            </androidx.appcompat.widget.Toolbar>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>


    <!-- ══════════════════════════════════════════
         SCROLLABLE BODY
    ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── SEARCH BAR ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/search_img"
                        app:tint="@color/text_muted" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:hint="Search questions..."
                        android:textSize="12sp"
                        android:textColor="@color/text_dark"
                        android:textColorHint="@color/text_muted"
                        android:maxLines="1"
                        android:inputType="text"
                        android:imeOptions="actionSearch" />

                    <ImageView
                        android:id="@+id/ivClearSearch"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/outline_close_24"
                        android:visibility="gone"
                        app:tint="@color/text_muted" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── CATEGORY CHIPS (horizontal scroll) ── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:paddingStart="16dp"
                android:scrollbars="none"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/categoryChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Chip: All Topics -->
                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Topics"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_cat_chip_active"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="7dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Chip: Products -->
                    <TextView
                        android:id="@+id/chipProducts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥛 Products"
                        android:textSize="11sp"
                       android:textStyle="bold"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/bg_cat_chip_default"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="7dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Chip: Delivery -->
                    <TextView
                        android:id="@+id/chipDelivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚚 Delivery"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/bg_cat_chip_default"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="7dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Chip: Subscription -->
                    <TextView
                        android:id="@+id/chipSubscription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄 Subscription"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/bg_cat_chip_default"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="7dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Chip: Quality -->
                    <TextView
                        android:id="@+id/chipQuality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Quality"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/bg_cat_chip_default"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="7dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Chip: Payment -->
                    <TextView
                        android:id="@+id/chipPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💳 Payment"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/bg_cat_chip_default"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="7dp"
                        android:layout_marginEnd="16dp"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>
            </HorizontalScrollView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- ── FAQ RECYCLERVIEW ── -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFaq"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="16dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never" />
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="50dp"
                    android:layout_marginTop="40dp" />
                <LinearLayout
                    android:id="@+id/lytNotFound"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="40dp"
                    android:visibility="gone"> <!-- Hidden by default -->

                    <!-- Use a Lottie animation or a simple ImageView -->
                 <com.airbnb.lottie.LottieAnimationView
                     android:id="@+id/animNotMatch"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     app:lottie_rawRes="@raw/emptylistt"
                     android:layout_gravity="center"
                     android:gravity="center"
                     android:orientation="vertical"
                     android:padding="40dp"
                     android:visibility="gone"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="No matching questions found"
                        android:fontFamily="@font/sora_bold"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Try using different keywords"
                        android:fontFamily="@font/sora_regular"
                        android:textColor="@color/text_muted"
                        android:textSize="13sp"
                        android:textAlignment="center" />
                </LinearLayout>




            </FrameLayout>


            <!-- ── HELP BANNER ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                android:layout_gravity="bottom"
                app:cardBackgroundColor="#0D1B0E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <!-- Chat icon -->
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="💬"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="@drawable/bg_help_icon"
                        android:layout_marginEnd="14dp" />

                    <!-- Text -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Still have questions?"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Our team replies within 30 minutes"
                            android:textSize="11sp"
                            android:textColor="#88FFFFFF"
                            android:fontFamily="@font/sora_regular"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                    <!-- Chat Now button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChatNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chat Now"
                        android:textSize="10sp"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/green_mid"
                        app:cornerRadius="5dp"
                   />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>



</androidx.coordinatorlayout.widget.CoordinatorLayout>