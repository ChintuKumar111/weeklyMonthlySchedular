<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.freshyzoappmodule.ui.Fragments.NewHome_Fragment"
        android:label="Home"
        tools:layout="@layout/fragment_new_home" />

    <fragment
        android:id="@+id/nav_product"
        android:name="com.example.freshyzoappmodule.ui.Fragments.ProductSectionFragment"
        android:label="Products"
        tools:layout="@layout/fragment_product_section" />

    <fragment
        android:id="@+id/nav_wallet"
        android:name="com.example.freshyzoappmodule.ui.Fragments.WalletFragment"
        android:label="Wallet"
        tools:layout="@layout/fragment_wallet" />

    <fragment
        android:id="@+id/nav_cart"
        android:name="com.example.freshyzoappmodule.ui.Fragments.CartFragment"
        android:label="Wallet"
        tools:layout="@layout/fragment_cart" />

    <fragment
        android:id="@+id/nav_account"
        android:name="com.example.freshyzoappmodule.ui.Fragments.AccountFragment"
        android:label="Account"
        tools:layout="@layout/fragment_account">
        <action
            android:id="@+id/action_nav_account_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_nav_account_to_addressFragment"
            app:destination="@id/addressFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/addressFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.AddressFragment"
        android:label="Address"
        tools:layout="@layout/fragment_address" />
    <fragment
        android:id="@+id/SubscribeFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.SubscriptionFragment"
        android:label="Subscribe"
        tools:layout="@layout/fragment_subscription" />

    <fragment
        android:id="@+id/ComplaintsFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.ComplaintsAssistanceFragment"
        android:label="complaintAssistance"
        tools:layout="@layout/fragment_complaints_assistance" />

    <fragment
        android:id="@+id/paymentAndWalletFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.PaymentAndWalletFragment"
        android:label="@string/payments_wallet"
        tools:layout="@layout/fragment_payment_and_wallet" />

    <fragment
        android:id="@+id/referralFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.ReferAndEarnFragment"
        android:label="@string/refer_earn"
        tools:layout="@layout/fragment_payment_and_wallet" />

    <fragment
        android:id="@+id/testReportFragment"
        android:name="com.example.freshyzoappmodule.ui.Fragments.TestReportFragment"
        android:label="@string/test_report"
        tools:layout="@layout/fragment_test_report" />


</navigation>